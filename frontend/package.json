{
  "name": "frontend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "run-p type-check \"build-only {@}\" --",
    "build-only": "vite build",
    "dev": "vite",
    "fmt": "prettier --write \"src/**/*.{js,ts,vue,json,css}\"",
    "lint": "eslint \"src/**/*.{js,ts,vue}\" --fix",
    "test": "vitest run",
    "type-check": "vue-tsc --build"
  },
  "dependencies": {
    "@primeuix/themes": "^2.0.3",
    "@primevue/forms": "^4.5.5",
    "@tailwindcss/vite": "^4.3.1",
    "primeicons": "^7.0.0",
    "primevue": "^4.5.5",
    "tailwindcss": "^4.3.1",
    "vue": "^3.5.32",
    "vue-router": "^5.0.4"
  },
  "devDependencies": {
    "@primevue/auto-import-resolver": "^4.5.5",
    "@tsconfig/node24": "^24.0.4",
    "@types/node": "^25.9.3",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^10.5.0",
    "eslint-plugin-vue": "^10.9.2",
    "npm-run-all2": "^8.0.4",
    "prettier-plugin-vue": "^1.1.6",
    "typescript": "~6.0.0",
    "unplugin-vue-components": "^32.1.0",
    "vite": "^8.0.8",
    "vite-plugin-vue-devtools": "^8.1.1",
    "vitest": "^4.1.8",
    "vue-tsc": "^3.3.5"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  }
