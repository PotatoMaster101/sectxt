{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "openapi-ts && run-p type-check \"build-only {@}\" --",
    "build-only": "vite build",
    "dev": "openapi-ts && vite",
    "lint": "eslint \"src/**/*.{js,ts,vue}\" --fix",
    "test": "openapi-ts && vitest run",
    "type-check": "vue-tsc --build"
  },
  "dependencies": {
    "@primeuix/themes": "^2.0.3",
    "@primevue/forms": "^4.5.5",
    "@tailwindcss/vite": "^4.3.2",
    "base64-js": "^1.5.1",
    "primeicons": "^7.0.0",
    "primevue": "^4.5.5",
    "tailwindcss": "^4.3.1",
    "vue": "^3.5.32",
    "vue-router": "^5.1.0"
  },
  "devDependencies": {
    "@hey-api/openapi-ts": "^0.99.0",
    "@primevue/auto-import-resolver": "^4.5.5",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@tsconfig/node24": "^24.0.4",
    "@types/node": "^26.1.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^10.6.0",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "eslint-plugin-vue": "^10.9.2",
    "npm-run-all2": "^8.0.4",
    "typescript": "~6.0.0",
    "typescript-eslint": "^8.62.1",
    "unplugin-vue-components": "^32.1.0",
    "vite": "^8.1.3",
    "vite-plugin-vue-devtools": "^8.1.5",
    "vitest": "^4.1.9",
    "vue-tsc": "^3.3.6"
